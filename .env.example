# Archivo de ejemplo .env (NO incluir secretos aquí si no quieres)
# Copia este archivo a .env y rellena los valores en tu entorno seguro

# Puerto opcional donde corre la app (por defecto 80)
PORT=80

# Credenciales de Spotify — deberás definirlas en tu entorno seguro (no en VCS)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Refresh token del propietario (opcional: puedes guardarlo como secret en Render)
SPOTIFY_REFRESH_TOKEN=

# Usuario admin para /api/login (opcional)
ADMIN_USER=
ADMIN_PASS=
